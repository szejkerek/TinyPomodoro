<Window x:Class="Pomodoro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pomodoro"
        Width="300"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display">

    <Border x:Name="RootBorder" CornerRadius="14" Padding="16,12,16,16"
            MouseLeftButtonDown="OnRootMouseLeftButtonDown">
        <StackPanel>

            <!-- Refresh · mode tabs · settings (single row) -->
            <Grid Margin="0,0,0,6">
                <Button x:Name="SyncButton" Style="{StaticResource IconButton}"
                        Content="↻" HorizontalAlignment="Left"
                        ToolTip="Odśwież zadania z Todoist" Click="OnSyncClick"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="TabPomodoro" Style="{StaticResource ModeTab}" Content="Pomodoro" Click="OnModeTabClick"/>
                    <Button x:Name="TabShort" Style="{StaticResource ModeTab}" Content="Krótka" Click="OnModeTabClick"/>
                    <Button x:Name="TabLong" Style="{StaticResource ModeTab}" Content="Długa" Click="OnModeTabClick"/>
                </StackPanel>
                <Button x:Name="SettingsButton" Style="{StaticResource IconButton}"
                        Content="⚙" HorizontalAlignment="Right"
                        ToolTip="Ustawienia" Click="OnSettingsClick"/>
            </Grid>

            <!-- Time -->
            <TextBlock x:Name="TimeText" Text="25:00" Foreground="White"
                       FontSize="64" FontWeight="Bold" HorizontalAlignment="Center"
                       Margin="0,2,0,8"/>

            <!-- Start / pause / reset -->
            <Grid Margin="0,0,0,8">
                <Button x:Name="StartButton" Content="START" Click="OnStartClick"
                        HorizontalAlignment="Center"
                        Cursor="Hand" Foreground="#BA4949" FontSize="18" FontWeight="Bold"
                        Padding="48,8">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="White" CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2"
                                                      Direction="270" Opacity="0.22"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Opacity" Value="0.92"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="ResetButton" Style="{StaticResource IconButton}"
                        Content="↺" FontSize="18" Width="36" Height="36"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        ToolTip="Reset" Click="OnResetClick"/>
            </Grid>

            <!-- Tasks -->
            <Border Background="#2E000000" CornerRadius="10" Padding="8">
                <StackPanel>
                    <Grid Margin="2,2,2,6">
                        <TextBlock Text="ZADANIA" Foreground="White" Opacity="0.6"
                                   FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <ComboBox x:Name="ProjectSelector" HorizontalAlignment="Right"
                                  MinWidth="150" MaxWidth="180"
                                  Style="{StaticResource ProjectCombo}"
                                  ItemContainerStyle="{StaticResource ProjectComboItem}"
                                  SelectedValuePath="Id"
                                  SelectionChanged="OnProjectChanged"
                                  ToolTip="Wybierz projekt Todoist">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Foreground="White"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>
                    <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="TaskItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Click="OnTaskClick" Tag="{Binding Id}" Cursor="Hand"
                                            HorizontalContentAlignment="Left" Margin="0,1">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg" Background="Transparent"
                                                        CornerRadius="4" Padding="4,5">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="○" Foreground="White" FontSize="14"
                                                                   Opacity="0.55" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Content}" Foreground="White"
                                                                   TextWrapping="Wrap" MaxWidth="220"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#33FFFFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <TextBlock x:Name="TasksHint" Foreground="White" Opacity="0.5"
                               FontSize="11" TextWrapping="Wrap" Margin="4,4,4,2"
                               Text="Dodaj token Todoist w ustawieniach (⚙), aby zobaczyć zadania."/>
                </StackPanel>
            </Border>

        </StackPanel>
    </Border>
</Window>
