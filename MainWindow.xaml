<Window x:Class="Pomodoro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pomodoro"
        Width="300"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <!-- Faux beat: each bar drifts its ScaleY on its own slow clock, so they wave out of sync.
             Small range + long durations = a gentle, barely-moving ripple. Driven from code on play/pause. -->
        <Storyboard x:Key="EqualizerBeat">
            <DoubleAnimation Storyboard.TargetName="Bar0"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                From="0.45" To="0.62" Duration="0:0:2.2" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="Bar1"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                From="0.60" To="0.48" Duration="0:0:2.6" BeginTime="0:0:0.30" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="Bar2"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                From="0.50" To="0.66" Duration="0:0:1.9" BeginTime="0:0:0.15" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="Bar3"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                From="0.64" To="0.50" Duration="0:0:2.4" BeginTime="0:0:0.40" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="Bar4"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                From="0.48" To="0.63" Duration="0:0:2.0" BeginTime="0:0:0.20" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="Bar5"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                From="0.58" To="0.46" Duration="0:0:2.5" BeginTime="0:0:0.35" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="Bar6"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                From="0.46" To="0.60" Duration="0:0:2.1" BeginTime="0:0:0.10" AutoReverse="True" RepeatBehavior="Forever"/>
        </Storyboard>
    </Window.Resources>

    <Border x:Name="RootBorder" CornerRadius="14" Padding="16,12,16,16"
            MouseLeftButtonDown="OnRootMouseLeftButtonDown">
        <StackPanel>

            <!-- Refresh · mode tabs · settings (single row) -->
            <Grid x:Name="TopRow" Margin="0,0,0,6">
                <Button x:Name="SyncButton" Style="{StaticResource IconButton}"
                        Content="↻" HorizontalAlignment="Left"
                        ToolTip="Refresh tasks" Click="OnSyncClick"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="TabPomodoro" Style="{StaticResource ModeTab}" Content="Pomodoro" Click="OnModeTabClick"/>
                    <Button x:Name="TabShort" Style="{StaticResource ModeTab}" Content="Short" Click="OnModeTabClick"/>
                    <Button x:Name="TabLong" Style="{StaticResource ModeTab}" Content="Long" Click="OnModeTabClick"/>
                </StackPanel>
                <Button x:Name="SettingsButton" Style="{StaticResource IconButton}"
                        Content="⚙" HorizontalAlignment="Right"
                        ToolTip="Settings" Click="OnSettingsClick"/>
            </Grid>

            <!-- Focus banner (only while the timer runs) -->
            <TextBlock x:Name="FocusLabel" Text="FOCUS MODE" Foreground="White"
                       FontSize="15" FontWeight="Bold" HorizontalAlignment="Center"
                       Opacity="0.65" Margin="0,4,0,0" Visibility="Collapsed"/>

            <!-- Time -->
            <TextBlock x:Name="TimeText" Text="25:00" Foreground="White"
                       FontSize="64" FontWeight="Bold" HorizontalAlignment="Center"
                       Margin="0,2,0,8"/>

            <!-- Start / pause / reset -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="HeatmapButton" Grid.Column="0" Style="{StaticResource IconButton}"
                        Content="🔥" FontSize="14" FontWeight="SemiBold"
                        Width="Auto" MinWidth="36" Height="36" Padding="8,0"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        ToolTip="Focus stats" Click="OnHeatmapClick"/>
                <Button x:Name="StartButton" Grid.Column="1" Content="START" Click="OnStartClick"
                        HorizontalAlignment="Center"
                        Cursor="Hand" Foreground="#BA4949" FontSize="18" FontWeight="Bold"
                        Padding="40,8">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="White" CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2"
                                                      Direction="270" Opacity="0.22"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Opacity" Value="0.92"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="ResetButton" Grid.Column="2" Style="{StaticResource IconButton}"
                        Content="↺" FontSize="18" Width="36" Height="36"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        ToolTip="Reset" Click="OnResetClick"/>
            </Grid>

            <!-- Focus radio (only while focusing, when enabled in settings) -->
            <Grid x:Name="RadioPanel" Margin="0,0,0,8" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Mute toggle: vector speaker, waves hidden + slash shown when muted -->
                <Button x:Name="RadioMuteButton" Grid.Column="0" Style="{StaticResource IconButton}"
                        VerticalAlignment="Center" ToolTip="Mute / unmute" Click="OnRadioMuteClick">
                    <Grid Width="16" Height="16">
                        <Path Fill="White" Opacity="0.85" Stretch="None"
                              Data="M1,6 L4,6 L8,2 L8,14 L4,10 L1,10 Z"/>
                        <Path x:Name="SoundWaves" Stroke="White" StrokeThickness="1.3" Opacity="0.85"
                              Data="M10,5 A4,4 0 0 1 10,11 M11.8,3 A7.5,7.5 0 0 1 11.8,13"/>
                        <Line x:Name="MuteSlash" X1="1" Y1="15" X2="15" Y2="1"
                              Stroke="White" StrokeThickness="1.4" Visibility="Collapsed"/>
                    </Grid>
                </Button>

                <!-- Beat-reactive bars; station name lives in the tooltip -->
                <StackPanel x:Name="Equalizer" Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Height="18" Margin="6,0">
                    <StackPanel.Resources>
                        <Style TargetType="Rectangle">
                            <Setter Property="Width" Value="3"/>
                            <Setter Property="Height" Value="18"/>
                            <Setter Property="Margin" Value="3.5,0"/>
                            <Setter Property="Fill" Value="White"/>
                            <Setter Property="Opacity" Value="0.8"/>
                            <Setter Property="RadiusX" Value="1.5"/>
                            <Setter Property="RadiusY" Value="1.5"/>
                            <Setter Property="VerticalAlignment" Value="Bottom"/>
                            <Setter Property="RenderTransformOrigin" Value="0.5,1"/>
                        </Style>
                    </StackPanel.Resources>
                    <Rectangle x:Name="Bar0"><Rectangle.RenderTransform><ScaleTransform ScaleY="0.55"/></Rectangle.RenderTransform></Rectangle>
                    <Rectangle x:Name="Bar1"><Rectangle.RenderTransform><ScaleTransform ScaleY="0.55"/></Rectangle.RenderTransform></Rectangle>
                    <Rectangle x:Name="Bar2"><Rectangle.RenderTransform><ScaleTransform ScaleY="0.55"/></Rectangle.RenderTransform></Rectangle>
                    <Rectangle x:Name="Bar3"><Rectangle.RenderTransform><ScaleTransform ScaleY="0.55"/></Rectangle.RenderTransform></Rectangle>
                    <Rectangle x:Name="Bar4"><Rectangle.RenderTransform><ScaleTransform ScaleY="0.55"/></Rectangle.RenderTransform></Rectangle>
                    <Rectangle x:Name="Bar5"><Rectangle.RenderTransform><ScaleTransform ScaleY="0.55"/></Rectangle.RenderTransform></Rectangle>
                    <Rectangle x:Name="Bar6"><Rectangle.RenderTransform><ScaleTransform ScaleY="0.55"/></Rectangle.RenderTransform></Rectangle>
                </StackPanel>

                <Button x:Name="RadioSkipButton" Grid.Column="2" Style="{StaticResource IconButton}"
                        VerticalAlignment="Center" ToolTip="Next station" Click="OnRadioSkipClick">
                    <Grid Width="16" Height="16">
                        <Path Fill="White" Opacity="0.85" Stretch="None"
                              Data="M3,3 L11,8 L3,13 Z M12,3 L14,3 L14,13 L12,13 Z"/>
                    </Grid>
                </Button>
                <Slider x:Name="RadioVolumeSlider" Grid.Column="3" Width="64"
                        Style="{StaticResource MiniSlider}"
                        Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1"
                        VerticalAlignment="Center" Margin="8,0,0,0"
                        ToolTip="Volume" ValueChanged="OnRadioVolumeChanged"/>
            </Grid>

            <!-- Tasks -->
            <Border x:Name="TasksPanel" Background="#2E000000" CornerRadius="10" Padding="8">
                <StackPanel>
                    <Grid Margin="2,2,2,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="SourceTodoist" Style="{StaticResource ModeTab}"
                                    Content="Todoist" FontSize="10" Padding="7,2"
                                    ToolTip="Show Todoist tasks" Click="OnSourceTodoistClick"/>
                            <Button x:Name="SourceClickUp" Style="{StaticResource ModeTab}"
                                    Content="ClickUp" FontSize="10" Padding="7,2"
                                    ToolTip="Show ClickUp tasks" Click="OnSourceClickUpClick"/>
                            <Button x:Name="SourceAsana" Style="{StaticResource ModeTab}"
                                    Content="Asana" FontSize="10" Padding="7,2"
                                    ToolTip="Work mode · no task integration" Click="OnSourceAsanaClick"/>
                        </StackPanel>
                        <ComboBox x:Name="ProjectSelector" Grid.Column="2" HorizontalAlignment="Right"
                                  MinWidth="110" MaxWidth="150"
                                  Style="{StaticResource ProjectCombo}"
                                  ItemContainerStyle="{StaticResource ProjectComboItem}"
                                  SelectedValuePath="Id"
                                  SelectionChanged="OnProjectChanged"
                                  ToolTip="Select Todoist project">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Foreground="White"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>
                    <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="TaskItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Whole row = focus the task (mouse-down, so it can't drag the window);
                                         the ○ button = complete it. The circle is a real Button, so its click
                                         is handled before the row ever sees it. -->
                                    <Border x:Name="row" Background="Transparent" CornerRadius="4" Padding="2,3"
                                            Margin="0,1" Cursor="Hand" Tag="{Binding Id}"
                                            MouseLeftButtonDown="OnTaskRowClick">
                                        <StackPanel x:Name="content" Orientation="Horizontal">
                                            <Button Click="OnTaskCircleClick" Tag="{Binding Id}" Cursor="Hand"
                                                    VerticalAlignment="Center" Margin="0,0,6,0"
                                                    ToolTip="Complete · click again to undo">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="circle" Background="Transparent"
                                                                CornerRadius="11" Width="22" Height="22">
                                                            <TextBlock x:Name="mark" Text="○" Foreground="White"
                                                                       FontSize="14" Opacity="0.55"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="circle" Property="Background" Value="#33FFFFFF"/>
                                                                <Setter TargetName="mark" Property="Opacity" Value="1"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                                <TextBlock x:Name="label" Text="{Binding Label}" Foreground="White"
                                                           TextWrapping="Wrap" MaxWidth="205"/>
                                                <!-- ClickUp: status tag, coloured by its workflow column -->
                                                <TextBlock x:Name="statusLabel" Text="{Binding Status}"
                                                           Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"
                                                           FontSize="9" FontWeight="SemiBold" Margin="0,1,0,0"/>
                                                <!-- Todoist: which section the task sits in (informational) -->
                                                <TextBlock x:Name="sectionLabel" Text="{Binding SectionName}" Foreground="White"
                                                           Opacity="0.4" FontSize="9" Margin="0,1,0,0"/>
                                                <!-- Due date, if set (both sources) -->
                                                <TextBlock x:Name="dueLabel" Text="{Binding DueDate}" Foreground="White"
                                                           Opacity="0.55" FontSize="9" Margin="0,1,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <Trigger SourceName="row" Property="IsMouseOver" Value="True">
                                            <Setter TargetName="row" Property="Background" Value="#22FFFFFF"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding Status}" Value="">
                                            <Setter TargetName="statusLabel" Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SectionName}" Value="">
                                            <Setter TargetName="sectionLabel" Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DueDate}" Value="">
                                            <Setter TargetName="dueLabel" Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsFocused}" Value="True">
                                            <Setter TargetName="row" Property="Background" Value="#40FFFFFF"/>
                                            <Setter TargetName="label" Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                        <!-- Completion pending: fade + strike over the undo window, restore on cancel. -->
                                        <DataTrigger Binding="{Binding IsCompleting}" Value="True">
                                            <Setter TargetName="label" Property="TextDecorations" Value="Strikethrough"/>
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="fade">
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="content"
                                                                         Storyboard.TargetProperty="Opacity"
                                                                         To="0.25" Duration="0:0:2"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="fade"/>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="content"
                                                                         Storyboard.TargetProperty="Opacity"
                                                                         To="1" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <TextBlock x:Name="TasksHint" Foreground="White" Opacity="0.5"
                               FontSize="11" TextWrapping="Wrap" Margin="4,4,4,2"
                               Text="Add a Todoist token in settings (⚙) to see your tasks."/>
                </StackPanel>
            </Border>

        </StackPanel>
    </Border>
</Window>
