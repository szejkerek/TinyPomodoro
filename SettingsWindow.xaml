<Window x:Class="Pomodoro.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ustawienia Pomodoro"
        Width="340" SizeToContent="Height"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#2B2B2B"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <Style x:Key="GroupTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Width" Value="60"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="16">
        <TextBlock Text="CZAS (MINUTY)" Style="{StaticResource GroupTitle}"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Pomodoro"/>
            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="PomodoroBox" Margin="0,3"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Krótka przerwa"/>
            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="ShortBox" Margin="0,3"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Długa przerwa"/>
            <TextBox   Grid.Row="2" Grid.Column="1" x:Name="LongBox" Margin="0,3"/>
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Długa przerwa co (pomodoro)"/>
            <TextBox   Grid.Row="3" Grid.Column="1" x:Name="IntervalBox" Margin="0,3"/>
        </Grid>

        <TextBlock Text="AUTOMATYZACJA" Style="{StaticResource GroupTitle}"/>
        <CheckBox x:Name="AutoBreaksBox" Content="Auto-start przerw"/>
        <CheckBox x:Name="AutoPomodorosBox" Content="Auto-start pomodoro"/>
        <CheckBox x:Name="SoundBox" Content="Dźwięk na koniec"/>
        <CheckBox x:Name="StartWithWindowsBox" Content="Uruchamiaj z Windowsem"/>

        <TextBlock Text="TODOIST" Style="{StaticResource GroupTitle}"/>
        <TextBlock Text="Token API"/>
        <PasswordBox x:Name="TokenBox" Margin="0,3" Padding="4,3"
                     Background="#3C3C3C" Foreground="#FFFFFF" BorderBrush="#555555"/>
        <TextBlock Text="Filtr (opcjonalnie, np. today | #Praca)" Margin="0,6,0,0"/>
        <TextBox x:Name="FilterBox" Margin="0,3" Width="Auto" HorizontalAlignment="Stretch"/>
        <TextBlock Text="Token zapisywany tylko lokalnie (%APPDATA%\Pomodoro)."
                   Foreground="#777777" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,0"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Anuluj" Click="OnCancelClick" Padding="14,5" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="Zapisz" Click="OnSaveClick" Padding="14,5" IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</Window>
