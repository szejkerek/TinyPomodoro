<Window x:Class="Pomodoro.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pomodoro Settings"
        Width="360" SizeToContent="Height"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#2B2B2B"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <Style x:Key="GroupTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#777777"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Width" Value="60"/>
        </Style>

        <!-- Dark flat tabs: header strip + a panel body, no default chrome. -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="6,6,0,0"
                                Padding="14,7" Margin="0,0,2,0">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3C3C3C"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="16">
        <TabControl>

            <!-- ===== TIMER ===== -->
            <TabItem Header="Timer">
                <StackPanel Background="#3C3C3C">
                    <StackPanel Margin="12,8,12,12">
                        <TextBlock Text="DURATION (MINUTES)" Style="{StaticResource GroupTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Pomodoro"/>
                            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="PomodoroBox" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Short break"/>
                            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="ShortBox" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Long break"/>
                            <TextBox   Grid.Row="2" Grid.Column="1" x:Name="LongBox" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Long break every (pomodoros)"/>
                            <TextBox   Grid.Row="3" Grid.Column="1" x:Name="IntervalBox" Margin="0,3"/>
                        </Grid>

                        <TextBlock Text="AUTOMATION" Style="{StaticResource GroupTitle}"/>
                        <CheckBox x:Name="AutoBreaksBox" Content="Auto-start breaks"/>
                        <CheckBox x:Name="AutoPomodorosBox" Content="Auto-start pomodoros"/>
                        <CheckBox x:Name="SoundBox" Content="Sound when finished"/>
                        <CheckBox x:Name="StartWithWindowsBox" Content="Start with Windows"/>
                        <CheckBox x:Name="FocusRadioBox" Content="Play focus radio while focusing"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- ===== TASKS ===== -->
            <TabItem Header="Tasks">
                <StackPanel Background="#3C3C3C">
                    <StackPanel Margin="12,8,12,12">
                        <TextBlock Text="TODOIST" Style="{StaticResource GroupTitle}"/>
                        <TextBlock Text="API token"/>
                        <PasswordBox x:Name="TokenBox" Margin="0,3" Padding="4,3"
                                     Background="#3C3C3C" Foreground="#FFFFFF" BorderBrush="#555555"/>
                        <TextBlock Text="Filter (optional, e.g. today | #Work)" Margin="0,6,0,0"/>
                        <TextBox x:Name="FilterBox" Margin="0,3" Width="Auto" HorizontalAlignment="Stretch"/>
                        <TextBlock Text="Token stored locally only (%APPDATA%\Pomodoro)."
                                   Style="{StaticResource Hint}"/>

                        <TextBlock Text="CLICKUP" Style="{StaticResource GroupTitle}"/>
                        <TextBlock Text="API token (pk_…)"/>
                        <PasswordBox x:Name="ClickUpTokenBox" Margin="0,3" Padding="4,3"
                                     Background="#3C3C3C" Foreground="#FFFFFF" BorderBrush="#555555"/>
                        <TextBlock Text="List ID (from the list URL, after /li/)" Margin="0,6,0,0"/>
                        <TextBox x:Name="ClickUpListBox" Margin="0,3" Width="Auto" HorizontalAlignment="Stretch"/>
                        <TextBlock Text="Tasks are pulled from this one ClickUp list."
                                   Style="{StaticResource Hint}"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- ===== BLOCKING ===== -->
            <TabItem Header="Blocking">
                <StackPanel Background="#3C3C3C">
                    <StackPanel Margin="12,8,12,12">
                        <TextBlock Text="FOCUS BLOCKER" Style="{StaticResource GroupTitle}"/>
                        <CheckBox x:Name="BlockDistractionsBox" Content="Block distractions during focus"/>
                        <TextBlock Text="Blocked sites (one domain per line)" Margin="0,6,0,0"/>
                        <TextBox x:Name="BlockedHostsBox" Margin="0,3" Width="Auto" HorizontalAlignment="Stretch"
                                 AcceptsReturn="True" TextWrapping="NoWrap" Height="72"
                                 VerticalScrollBarVisibility="Auto"/>
                        <TextBlock Text="Blocked apps (one .exe name per line)" Margin="0,6,0,0"/>
                        <TextBox x:Name="BlockedProcessesBox" Margin="0,3" Width="Auto" HorizontalAlignment="Stretch"
                                 AcceptsReturn="True" TextWrapping="NoWrap" Height="48"
                                 VerticalScrollBarVisibility="Auto"/>
                        <TextBlock Text="Requires admin. Browsers with Secure DNS may bypass site blocking."
                                   Style="{StaticResource Hint}"/>

                        <TextBlock Text="WORK TOOLS" Style="{StaticResource GroupTitle}"/>
                        <CheckBox x:Name="BlockWorkToolsBox" Content="Block work tools outside work context"/>
                        <TextBlock Text="Work sites (one domain per line)" Margin="0,6,0,0"/>
                        <TextBox x:Name="WorkBlockedHostsBox" Margin="0,3" Width="Auto" HorizontalAlignment="Stretch"
                                 AcceptsReturn="True" TextWrapping="NoWrap" Height="48"
                                 VerticalScrollBarVisibility="Auto"/>
                        <TextBlock Text="Work apps (one .exe name per line)" Margin="0,6,0,0"/>
                        <TextBox x:Name="WorkBlockedProcessesBox" Margin="0,3" Width="Auto" HorizontalAlignment="Stretch"
                                 AcceptsReturn="True" TextWrapping="NoWrap" Height="48"
                                 VerticalScrollBarVisibility="Auto"/>
                        <TextBlock Text="Blocked during life (Todoist) and hobby (ClickUp) focus, allowed during work (Asana) focus."
                                   Style="{StaticResource Hint}"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

        </TabControl>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Click="OnCancelClick" Padding="14,5" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="Save" Click="OnSaveClick" Padding="14,5" IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</Window>
